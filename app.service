[Unit]
Description=Catty Reminders App
After=network.target

[Service]
User=romaerror5
WorkingDirectory=/home/romaerror5/Desktop/devops/catty-reminders-app
EnvironmentFile=/home/romaerror5/Desktop/devops/catty-reminders-app/.env
ExecStart=/usr/bin/python3 -m uvicorn app.main:app --host 0.0.0.0 --port 8181
Restart=always

[Install]
WantedBy=multi-user.target